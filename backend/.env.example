# ============================================================
# TutorIA Web V24 — Variáveis de ambiente (backend)
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env no Git!
# ============================================================

# Supabase — encontre em: Project Settings > API
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_ANON_KEY=eyJ...sua_anon_key...
SUPABASE_SERVICE_KEY=eyJ...sua_service_role_key...  # só no backend!

# CORS — URLs do frontend que podem chamar a API
ALLOWED_ORIGINS=http://localhost:5173,https://tutor-ia.vercel.app

# Anthropic (para o chat IA)
ANTHROPIC_API_KEY=sk-ant-...

# Opcional — WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Opcional — Gmail OAuth2
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
